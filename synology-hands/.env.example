# Copy to .env (chmod 600) and fill in. NEVER commit .env (it's gitignored).
#
#   cp .env.example .env && chmod 600 .env

# Shared bearer token. Generate with:  openssl rand -hex 32
# Use the SAME value in `claude mcp add ... --header "Authorization: Bearer <token>"`.
RELAY_TOKEN=

# Identifier for this NAS in the audit log.
NODE_ID=nas1

# Defense-in-depth: only these Tailscale identities may call tools (comma-separated).
# This is your Tailscale login (see `tailscale status`), NOT necessarily your git email.
# Leave empty to rely on token + Tailscale ACL alone (recommended for first bring-up,
# then tighten once you've confirmed your identity in the audit log).
ALLOWED_USERS=you@example.com

# Optional overrides (defaults shown):
# PORT=8787
# AUDIT_DIR=/var/log/mcp
# GRACEFUL_TIMEOUT=30
