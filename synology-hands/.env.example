# Copy to .env (chmod 600) and fill in. NEVER commit .env (it's gitignored).
#
#   cp .env.example .env && chmod 600 .env

# Shared bearer token. Generate with:  openssl rand -hex 32
# Use the SAME value in `claude mcp add ... --header "Authorization: Bearer <token>"`.
# Must be >= 16 chars — the relay refuses shorter tokens at startup.
RELAY_TOKEN=

# Identifier for this NAS in the audit log.
NODE_ID=nas1

# Defense-in-depth: only these Tailscale identities may call tools (comma-separated).
# This is your Tailscale login (see `tailscale status`), NOT necessarily your git email.
# Leave empty to rely on token + Tailscale ACL alone (recommended for first bring-up,
# then tighten once you've confirmed your identity in the audit log).
ALLOWED_USERS=you@example.com

# Optional overrides (defaults shown):
# PORT=8787
# AUDIT_DIR=/var/log/mcp
# GRACEFUL_TIMEOUT=30

# --- Output cap: truncates run() AND every Tier-A tool's stdout/stderr. ---
# OUTPUT_CAP is the working cap; OUTPUT_CAP_MAX is a hard ceiling no value (env or per-call
# run(max_bytes=...)) may exceed. Raising OUTPUT_CAP fixes silent truncation of large output.
# OUTPUT_CAP=65536
# OUTPUT_CAP_MAX=2097152

# --- Policy tuning (additive-first; values are comma/newline-separated). ---
# RUN_DENY_EXTRA: extra catastrophic-command regexes, APPENDED to the built-in denylist (never
# replaces it). Invalid regexes fail loudly at startup.
# RUN_DENY_EXTRA=
# READ_ALLOW_EXTRA / READ_DENY_EXTRA: extra read_file allow/deny roots, ADDED to the appliance
# defaults. Set-but-empty is a no-op (never wipes a default).
# READ_ALLOW_EXTRA=
# READ_DENY_EXTRA=
# READ_POLICY_OVERRIDE=1 makes the *_EXTRA lists fully REPLACE the appliance read defaults
# (logged loudly at startup). Leave unset for additive behavior.
# READ_POLICY_OVERRIDE=
