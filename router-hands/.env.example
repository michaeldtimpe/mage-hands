# Copy to .env (chmod 600) and fill in. NEVER commit .env (it's gitignored).
#
#   cp .env.example .env && chmod 600 .env

# Shared bearer token. Generate with:  openssl rand -hex 32
# Use the SAME value in `claude mcp add ... --header "Authorization: Bearer <token>"`.
# Must be >= 16 chars — the relay refuses shorter tokens at startup.
RELAY_TOKEN=

# Identifier for this relay in the audit log (also the tailnet hostname of the sidecar node).
NODE_ID=router1

# Defense-in-depth: only these Tailscale identities may call tools (comma-separated).
# This is your Tailscale login (see `tailscale status`), NOT your git email. Leave EMPTY for first
# bring-up (token + ACL only), then tighten once you've confirmed your identity in the audit log.
ALLOWED_USERS=

# --- Tailscale sidecar -------------------------------------------------------
# Auth key for the `router1` node. Create in the admin console (Settings -> Keys).
# MUST be reusable + ephemeral + pre-approved with a tag (e.g. tag:relay). Auth keys EXPIRE; once
# the node has joined, identity persists in ./ts-state, but a recreate after expiry needs a fresh key.
TS_AUTHKEY=tskey-auth-xxxxxxxxxxxx

# --- Router SSH target (the relay SSHes OUT to the ASUS router) ---------------
ROUTER_HOST=192.168.1.1               # LAN IP or hostname of the ASUS/Merlin router
ROUTER_USER=admin                     # router SSH user (Merlin: the admin account)
ROUTER_PORT=22                        # dropbear SSH port (change if you moved it)
ROUTER_SSH_KEY=/secrets/router_key    # private key path INSIDE the container (bind-mounted ro)
ROUTER_KNOWN_HOSTS=/secrets/known_hosts   # pinned router host key INSIDE the container
# With ROUTER_STRICT_HOST_KEY=yes (the default) the relay REFUSES TO START if this file is
# missing or empty — pin the key first (ssh-keyscan) or bootstrap once with accept-new.
# ROUTER_STRICT_HOST_KEY=yes          # 'yes' (pinned) | 'accept-new' (FIRST deploy only, then flip back)
# ROUTER_CONNECT_TIMEOUT=10           # ssh ConnectTimeout (seconds)
# ROUTER_CONTROL_PERSIST=60           # SSH session-reuse seconds; set 0 if dropbear rejects ControlMaster
# ROUTER_REMOTE_SHELL=/bin/sh         # absolute shell for `sh -c` payloads; Broadcom ASUS fw ships a rogue `sh` memory-tool on PATH, so a bare `sh -c` breaks — keep this absolute
# ROUTER_WIFI_IFACES=                 # optional space/comma list overriding the nvram-probed WiFi ifaces

# --- Tier-C raw exec (ON by default on a router) -----------------------------
# run() is registered UNLESS this is set to false/0/no. It is arbitrary root over SSH on a
# soft-brickable target — token possession then effectively grants constrained root shell. It keeps
# the dry-run/exec_token gate + the router denylist (firmware flash / nvram-erase / factory reset /
# mtd writes + the reboot backstops, incl. the indirect Merlin paths service reboot / init 6 /
# busybox reboot / rc reboot / killall rc — so reboot_router stays the only intended reboot path).
# Set ROUTER_ENABLE_RUN=false where that posture is unacceptable.
ROUTER_ENABLE_RUN=

# --- Relay bind (REQUIRED for the sidecar netns) -----------------------------
# Must be loopback so `tailscale serve` can proxy to it inside the shared namespace, and 8788
# (not 8787) to avoid clashing with synology-hands if ever co-located. serve.json's proxy target
# must match PORT.
BIND_HOST=127.0.0.1
PORT=8788

# Optional overrides (defaults shown):
# AUDIT_DIR=/var/log/mcp
# GRACEFUL_TIMEOUT=30
# OUTPUT_CAP=65536                     # truncate run() AND every Tier-A tool's stdout/stderr
# RUN_DENY_EXTRA=                      # extra regexes APPENDED to the run() denylist
# READ_ALLOW_EXTRA=                    # extra read roots APPENDED to the read policy
# READ_DENY_EXTRA=                     # extra denied paths APPENDED to the read policy
